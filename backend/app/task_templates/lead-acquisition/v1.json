{
  "template_id": "lead-acquisition",
  "version": "1.0.0",
  "name": "线索采集与触达",
  "description": "抓取评论线索并按策略评论/关注/私信；Phase 2 启用完整 executor。",
  "executor_id": "lead_acquisition",
  "platforms": ["douyin", "xiaohongshu"],
  "phases": [
    { "id": "crawl", "capability": "pipeline_keyword_comments", "retry": 2, "depends_on": [] },
    { "id": "normalize", "capability": "internal.normalize_leads", "retry": 0, "depends_on": ["crawl"] },
    { "id": "match", "capability": "internal.match_leads", "retry": 0, "depends_on": ["normalize"] },
    { "id": "outreach", "capability": "social_roam_outreach", "retry": 1, "depends_on": ["match"] },
    { "id": "finalize", "capability": "internal.summarize", "retry": 0, "depends_on": ["outreach"] }
  ],
  "default_spec": {
    "task_name": "",
    "keyword": "",
    "platform": "douyin",
    "account_id": "default",
    "region": null,
    "crawl": {
      "video_publish_days": null,
      "comment_days": 3,
      "target_leads": 100,
      "video_limit_per_batch": 20,
      "max_batches": 50,
      "force_refresh": false
    },
    "action_policy": {
      "comment_ratio": 50,
      "dm_ratio": 50,
      "interval_min_sec": 10,
      "interval_max_sec": 30
    },
    "daily_limits": {
      "max_comment_replies": 30,
      "max_follows": 30,
      "max_dms": 30
    },
    "provider": "deepseek",
    "timeout_seconds": 1200
  }
}
