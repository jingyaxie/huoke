APP_NAME=Douyin Hot Monitor
DEBUG=false
DATABASE_URL=mysql+pymysql://douyin:douyin@mysql:3306/douyin_hot?charset=utf8mb4
FRONTEND_ORIGIN=http://localhost:5173
DOUYIN_HOT_URL=https://www.douyin.com/hot
DOUYIN_HEADLESS=true
DEFAULT_PLATFORM=douyin
XHS_HOME_URL=https://www.xiaohongshu.com
XHS_EXPLORE_URL=https://www.xiaohongshu.com/explore
XHS_HEADLESS=true
HUOSHAN_HOME_URL=https://www.huoshan.com
HUOSHAN_HOT_URL=https://www.douyin.com/hot
HUOSHAN_HEADLESS=true
# 火山 seed 用户（Douyin sec_uid / share.huoshan to_user_id），逗号或 JSON 数组
HUOSHAN_SEED_USER_IDS=
# seed_then_fallback | seed_only | douyin_only
HUOSHAN_HOT_MODE=seed_then_fallback
KUAISHOU_HOME_URL=https://www.kuaishou.com
KUAISHOU_HEADLESS=true
KUAISHOU_VNC_URL=http://localhost:6080/vnc.html?autoconnect=true&resize=scale
ANTIBOT_ENABLED=true
ANTIBOT_STEALTH_ENABLED=true
ANTIBOT_REQUIRE_LOGIN=true
ANTIBOT_DELAY_MIN_MS=2000
ANTIBOT_DELAY_MAX_MS=6000
ANTIBOT_USER_AGENT=
ANTIBOT_VIEWPORT_WIDTH=1440
ANTIBOT_VIEWPORT_HEIGHT=1200
ANTIBOT_LOCALE=zh-CN
# 租户级覆盖写入 storage/tenants/{tenant_id}/antibot.json，见 GET/PUT /api/tenants/{tenant_id}/antibot
DEFAULT_TENANT_ID=default
DOUYIN_TENANTS_DIR=storage/douyin/tenants
DOUYIN_STORAGE_STATE_PATH=storage/douyin/storage_state.json
# 生产环境建议设为 true；开启后请求须带 X-API-Key，且只能操作 Key 所属租户
TENANT_AUTH_ENABLED=false
TENANT_AUTH_PEPPER=change-me-in-production
USER_AUTH_PEPPER=change-me-in-production
JWT_SECRET=change-me-jwt-secret-in-production
JWT_EXPIRE_MINUTES=10080
# AI销售等外部系统 SSO 联动（POST /api/auth/bridge，请求头 X-Huoke-Bridge-Secret）
HUOKE_BRIDGE_SECRET=
ADMIN_API_SECRET=
TENANT_BOOTSTRAP_API_KEYS={"default":"dev-local-key"}
STORAGE_STATE_ENCRYPTION_KEY=
DOUYIN_PROFILE_DIR=storage/douyin/profile
CRAWL_HOUR=8
CRAWL_MINUTE=0
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
AGENT_MAX_STEPS=100
AGENT_DEFAULT_PROVIDER=deepseek
AGENT_HEADLESS=true
AGENT_VISION_ENABLED=true
AGENT_VISION_MODEL=
AGENT_MAX_HISTORY_MESSAGES=40
AGENT_DEFAULT_RUN_MODE=auto
AGENT_CHECKPOINTS_ENABLED=true
AGENT_CHECKPOINT_MAX_COUNT=20
AGENT_SUBAGENT_MAX_STEPS=100
AGENT_STREAM_ENABLED=true
AGENT_COMPRESS_ENABLED=true
AGENT_COMPRESS_THRESHOLD_MESSAGES=30
AGENT_COMPRESS_KEEP_RECENT=12
AGENT_DREAM_ENABLED=true
AGENT_DREAM_AUTO=true
AGENT_DREAM_USE_LLM=false
AGENT_DREAM_INJECT_MAX=5
