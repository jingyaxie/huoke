APP_NAME=Douyin Hot Monitor
DEBUG=false
DATABASE_URL=mysql+pymysql://douyin:douyin@mysql:3306/douyin_hot?charset=utf8mb4
FRONTEND_ORIGIN=http://localhost:5173
DOUYIN_HOT_URL=https://www.douyin.com/hot
DOUYIN_HEADLESS=true
DEFAULT_PLATFORM=douyin
XHS_HOME_URL=https://www.xiaohongshu.com
XHS_EXPLORE_URL=https://www.xiaohongshu.com/explore
XHS_HEADLESS=true
ANTIBOT_ENABLED=true
ANTIBOT_STEALTH_ENABLED=true
ANTIBOT_REQUIRE_LOGIN=true
ANTIBOT_DELAY_MIN_MS=2000
ANTIBOT_DELAY_MAX_MS=6000
ANTIBOT_USER_AGENT=
ANTIBOT_VIEWPORT_WIDTH=1440
ANTIBOT_VIEWPORT_HEIGHT=1200
ANTIBOT_LOCALE=zh-CN
# 租户级覆盖写入 storage/tenants/{tenant_id}/antibot.json，见 GET/PUT /api/tenants/{tenant_id}/antibot
DEFAULT_TENANT_ID=default
DOUYIN_TENANTS_DIR=storage/douyin/tenants
DOUYIN_STORAGE_STATE_PATH=storage/douyin/storage_state.json
TENANT_AUTH_ENABLED=false
TENANT_AUTH_PEPPER=change-me-in-production
ADMIN_API_SECRET=
TENANT_BOOTSTRAP_API_KEYS={"default":"dev-local-key"}
STORAGE_STATE_ENCRYPTION_KEY=
DOUYIN_PROFILE_DIR=storage/douyin/profile
CRAWL_HOUR=8
CRAWL_MINUTE=0
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
