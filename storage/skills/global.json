    {
      "id": "reply-comment",
      "name": "回复评论",
      "description": "从 DB 定位评论所属视频/笔记，打开内容页后直接调用页面 JS 接口回复（builtin，全平台）",
      "type": "builtin",
      "enabled": true,
      "scope": "global",
      "parameters": [
        {"name": "comment_id", "type": "string", "description": "目标评论 ID（必填；优先从 DB 定位 content_url）", "required": true},
        {"name": "reply_text", "type": "string", "description": "回复内容", "required": true},
        {"name": "content_id", "type": "string", "description": "内容 ID（可选，缩小 DB 查询）", "required": false},
        {"name": "comment_text", "type": "string", "description": "评论原文（可选，辅助 DB 定位）", "required": false},
        {"name": "comment_hint", "type": "string", "description": "同 comment_text（兼容旧参数）", "required": false},
        {"name": "video_url", "type": "string", "description": "视频链接（DB 无记录时必填）", "required": false},
        {"name": "note_url", "type": "string", "description": "笔记链接（DB 无记录时必填）", "required": false},
        {"name": "photo_author_id", "type": "string", "description": "快手视频作者 ID（可选，无法自动解析时传入）", "required": false},
        {"name": "show_browser", "type": "boolean", "description": "可见浏览器", "required": false, "default": false}
      ],
      "content": "流程：content_comments 表按 comment_id 定位 content_url → 直接打开该视频/笔记页 → 调用 comment/publish 或 comment/post 或 visionAddComment 接口，无需翻页找评论。",
