# 部署机配置示例（复制为 .env.deploy.local）
PROD_SSH_HOST=39.105.130.85
PROD_SSH_USER=root
# PROD_SSH_PASSWORD=your_password

# 线上代码目录（当前项目独立目录）
PROD_ROOT=/root/workspace/huoke

# docker compose 项目名，避免影响服务器其他项目
PROD_PROJECT_NAME=huoke

# 可选：健康检查地址（默认 backend 容器服务）
# HEALTH_URL=http://127.0.0.1:8000/api/health

