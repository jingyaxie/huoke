# 部署机配置示例（复制为 .env.deploy.local）
PROD_SSH_HOST=47.116.76.248
PROD_SSH_USER=root
# 密钥登录（推荐）
PROD_SSH_KEY=/path/to/your.pem
# 或密码登录（二选一）
# PROD_SSH_PASSWORD=your_password

# 线上代码目录（当前项目独立目录）
PROD_ROOT=/root/workspace/huoke

# docker compose 项目名，避免影响服务器其他项目
PROD_PROJECT_NAME=huoke

# 生产默认：构建前端 + 配置宿主机 Nginx
BUILD_FRONTEND=1
SETUP_NGINX=1
NGINX_SERVER_NAME=47.116.76.248

# 健康检查（容器内地址，配合 docker-compose.prod.yml 本机绑定）
# HEALTH_URL=http://127.0.0.1:8000/api/health

